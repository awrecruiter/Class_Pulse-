		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"validate": "npx tsc --noEmit && npm run lint && npm run test:run",
		"demo:seed": "npx tsx scripts/demo-seed.ts",
		"demo:teardown": "npx tsx scripts/demo-teardown.ts"
	},
	"dependencies": {
