{
	"name": "class-pulse",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest",
