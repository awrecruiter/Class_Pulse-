# Database
# Recommended regulated target: AWS RDS or Aurora PostgreSQL with TLS required.
DATABASE_URL=postgresql://user:pass@db-name.cluster-xxxx.us-east-1.rds.amazonaws.com/app?sslmode=require

# Neon Auth
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32
ALLOW_DEV_AUTH_BYPASS=false

# Google OAuth (production only — dev uses shared Neon credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (AI Instructional Coach + Behavior Coach + Ambient Scan + Academic Guidance)
ANTHROPIC_API_KEY=sk-ant-...

# AWS SNS (Phase 9 — SMS parent notifications; optional — incidents still log if not set)
# Free tier: 100 SMS/month free, then $0.0025/msg USA
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
